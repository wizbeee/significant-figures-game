# 유효숫자 마스터 — 환경변수 예제
# 복사해서 .env로 만들거나, 시스템 환경변수로 직접 설정
# 모두 미설정 시 안전한 기본값 적용 (이 파일 자체는 필수 X)

# ===== 네트워크 =====
PORT=8093                       # 서버 포트
HOST=0.0.0.0                    # 바인딩 주소 (0.0.0.0 = 모든 인터페이스)

# ===== 데이터 저장 =====
DATA_DIR=./data                 # 영구 데이터 폴더 (Render: /var/data)

# ===== 토큰 유효시간 =====
# 학생: 점심+저녁 단절 운영 시 48시간 권장
# 교사: 24~72시간 권장 (재로그인 번거로움 vs 보안)
STUDENT_TOKEN_TTL_HOURS=24
TEACHER_TOKEN_TTL_HOURS=24

# ===== 보안 =====
# CORS 화이트리스트 (운영 시 본인 도메인 명시 권장)
# 예: CORS_ORIGIN=https://sigfig.example.com
CORS_ORIGIN=*

# 레거시 default 교실 초기 비밀번호 (마이그레이션용 — 보통 변경 X)
TEACHER_PASSWORD=3000

# ===== 데이터 한계 =====
LB_CAP=5000                     # 글로벌 점수판 상한 (기본 5000, 학기 누적 큰 학교는 10000)

# ===== 로그 =====
# 별도 파일로도 로그 출력 (prefix, 일별 자동 회전)
# 예: LOG_FILE=./logs/sigfig
LOG_FILE=
