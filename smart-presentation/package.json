{
  "name": "smart-presentation",
  "version": "1.0.0",
  "description": "스마트 프레젠테이션 - AI 기반 교육용 발표자료 제작 도구",
  "main": "src/main/main.js",
  "scripts": {
    "start": "concurrently \"npm run dev:react\" \"wait-on http://localhost:3002 && npm run dev:electron\"",
    "dev:react": "cross-env PORT=3002 react-scripts start",
    "dev:electron": "cross-env NODE_ENV=development electron .",
    "build": "react-scripts build && npm run build:electron",
    "build:electron": "electron-builder --win",
    "build:win": "react-scripts build && electron-builder --win",
    "build:mac": "react-scripts build && electron-builder --mac"
  },
  "keywords": ["electron", "react", "presentation", "education", "ai", "slides"],
  "author": "SmartPresentation",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.0",
    "date-fns": "^3.0.0",
    "electron-store": "^8.1.0",
    "express": "^4.18.2",
    "fabric": "^6.0.0",
    "jspdf": "^2.5.1",
    "jszip": "^3.10.1",
    "pptxgenjs": "^3.12.0",
    "qrcode": "^1.5.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-scripts": "5.0.1",
    "socket.io": "^4.7.0",
    "uuid": "^9.0.0",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "wait-on": "^7.2.0"
  },
  "homepage": "./",
  "build": {
    "appId": "com.smartpresentation.app",
    "productName": "스마트 프레젠테이션",
    "extends": null,
    "files": [
      "build/**/*",
      "src/main/**/*"
    ],
    "extraMetadata": {
      "main": "src/main/main.js"
    },
    "win": {
      "target": ["nsis"],
      "icon": "public/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "eslintConfig": {
    "extends": ["react-app"]
  },
  "browserslist": {
    "production": [">0.2%", "not dead", "not op_mini all"],
    "development": ["last 1 chrome version"]
  }
}
