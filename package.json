{
  "name": "significant-figures-game",
  "version": "2.0.0",
  "description": "유효숫자 마스터 — 고등학교 과학 수업용 실시간 퀴즈 게임 (싱글/멀티/대전)",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "test": "node --test test/analyze.test.js test/parseUserNum.test.js test/hasBadWord.test.js",
    "test:watch": "node --test --watch test/analyze.test.js test/parseUserNum.test.js test/hasBadWord.test.js",
    "syntax": "node -c server.js && echo OK",
    "health": "curl -s http://localhost:8093/api/health | node -e \"let s='';process.stdin.on('data',c=>s+=c).on('end',()=>console.log(JSON.parse(s)))\"",
    "version": "node -e \"console.log(require('child_process').execSync('git rev-parse --short HEAD').toString().trim())\""
  },
  "engines": {
    "node": ">=18"
  },
  "author": "wizbeee",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/wizbeee/significant-figures-game.git"
  }
}
